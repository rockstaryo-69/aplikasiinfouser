# ─────────────────────────────────────────────
#  CyberScope OSINT Platform — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=8h

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=cyberscope
PG_USER=postgres
PG_PASSWORD=yourpassword

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Threat Intelligence APIs (get free keys from providers)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# WHOIS API (optional)
WHOIS_API_KEY=your_whois_api_key_here

# Scanning
SCAN_TIMEOUT_MS=30000
SCAN_RATE_LIMIT_PER_MINUTE=10
MAX_QUEUE_JOBS=50

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Puppeteer (screenshot service)
PUPPETEER_TIMEOUT_MS=15000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/cyberscope.log
